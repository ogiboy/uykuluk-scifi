{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Generated by chunk init and tuned for bounded UykulukSciFi validation.",
  "permissions": { "allow": ["Bash(chunk:*)"] },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_WORKING_DIR:-${CLAUDE_PROJECT_DIR:-.}}\" \u0026\u0026 CHUNK_NO_TELEMETRY=1 chunk validate quick",
            "timeout": 180
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_WORKING_DIR:-${CLAUDE_PROJECT_DIR:-.}}\" \u0026\u0026 CHUNK_NO_TELEMETRY=1 chunk validate quick",
            "timeout": 180
          }
        ]
      }
    ]
  }
}
