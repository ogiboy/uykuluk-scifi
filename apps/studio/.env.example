# Optional Studio observability. Blank values keep Sentry disabled and local operation unchanged.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_TRACES_SAMPLE_RATE=0

# Server-only credential inherited by guarded CLI actions. Never rename this to NEXT_PUBLIC_*.
ELEVENLABS_API_KEY=

# Server-only credential inherited by guarded hosted-visual actions.
BFL_API_KEY=

# Source-map upload is build-time only. Keep the token in local/CI secret storage, never in Git.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
