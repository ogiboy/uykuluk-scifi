{
  "name": "uykuluk-scifi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Approval-gated local-first producer CLI and Studio shell for the UykulukSciFi YouTube workflow.",
  "license": "LGPL-3.0-only",
  "author": {
    "name": "Ogiboy",
    "email": "oguzcantoptas@gmail.com"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "producer": "tsx src/cli.ts",
    "studio": "pnpm --filter @uykulukscifi/studio dev",
    "studio:build": "pnpm --filter @uykulukscifi/studio build",
    "studio:lint": "pnpm --filter @uykulukscifi/studio lint",
    "studio:start": "pnpm --filter @uykulukscifi/studio start",
    "studio:test:e2e": "playwright test",
    "studio:typecheck": "pnpm --filter @uykulukscifi/studio typecheck",
    "test": "vitest run",
    "tts:piper:setup": "tsx scripts/tts/setup-piper-model.ts",
    "qa:usage": "node scripts/usage-smoke.mjs",
    "qa:browser": "pnpm studio:test:e2e",
    "qa:modularity": "node scripts/qa/modularity-gate.mjs --fail-on-findings",
    "security:dependencies": "pnpm audit --audit-level=high",
    "security:secrets": "node scripts/security/secret-scan.mjs",
    "security:check": "pnpm security:secrets",
    "changelog:check": "node scripts/release/check-changelog-marker.mjs",
    "release:check": "tsx scripts/release/check-conventional-commits.ts",
    "release:apply": "tsx scripts/release/apply-release.ts",
    "version:plan": "tsx scripts/release/version-plan.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm lint && pnpm studio:lint && pnpm typecheck && pnpm build && pnpm build:smoke && pnpm test && pnpm studio:typecheck && pnpm studio:build && pnpm qa:modularity && pnpm security:check && pnpm changelog:check && pnpm release:check && pnpm format:check",
    "lint": "node --max-old-space-size=4096 ./node_modules/eslint/bin/eslint.js src tests scripts eslint.config.js vitest.config.ts playwright.config.ts",
    "typecheck": "tsc --noEmit",
    "build": "node scripts/build.mjs",
    "build:smoke": "node scripts/qa/build-smoke.mjs",
    "test:coverage": "vitest run --coverage --coverage.reporter=lcov --coverage.reportsDirectory=.ai/qa/artifacts/sonar/coverage",
    "sonar": "scripts/qa/run_sonar_scan.sh",
    "sonar:local": "scripts/qa/run_sonar_scan.sh",
    "sonar:cloud": "SONAR_HOST_URL=https://sonarcloud.io SONAR_PROJECT_KEY=ogiboy_uykuluk-scifi SONAR_ORGANIZATION=ogiboy SONAR_TOKEN_KEYCHAIN_SERVICE=codex-sonarcloud-token scripts/qa/run_sonar_scan.sh",
    "sonar:start": "scripts/sonarqube/start-local.sh",
    "sonar:stop": "scripts/sonarqube/stop-local.sh",
    "sonar:status": "scripts/sonarqube/status-local.sh"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "ink": "^7.1.0",
    "react": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@sonar/scan": "^4.3.8",
    "@types/node": "^25.9.4",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
