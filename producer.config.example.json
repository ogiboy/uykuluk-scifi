        "modelId": "eleven_v3",
        "languageCode": "tr",
        "applyTextNormalization": "auto",
        "seed": 42,
        "maxCharactersPerRequest": 4500,
        "outputFormat": "wav_24000",
        "timeoutMs": 300000,
        "maxRetries": 0,
