  "budgets": { "perVideoUsd": 0.5, "dailyUsd": 1, "weeklyUsd": 5, "requireApprovalAboveUsd": 0.01 },
  "safeguards": {
    "requireIdeaApproval": true,
    "requireScriptApproval": true,
    "requireRenderApproval": true,
