#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

step() {
  printf '\n[%s/5] %s\n' "$1" "$2"
}

if ! command -v node >/dev/null 2>&1; then
  printf 'Node.js 22 or newer is required. Install Node with NVM, then run ./studio again.\n' >&2
  exit 1
fi

node -e 'const major=Number(process.versions.node.split(".")[0]); if (major < 22) { console.error(`Node.js 22 or newer is required; current version is ${process.versions.node}.`); process.exit(1); }'

if command -v pnpm >/dev/null 2>&1; then
  PNPM=(pnpm)
elif command -v corepack >/dev/null 2>&1; then
  PNPM=(corepack pnpm)
else
  printf 'pnpm is unavailable. Enable Corepack for this Node installation, then run ./studio again.\n' >&2
  exit 1
fi

step 1 'Installing project dependencies'
"${PNPM[@]}" install --frozen-lockfile --prefer-offline

step 2 'Checking the optional Studio-managed Python environment'
scripts/mflux-env.sh status

step 3 'Preparing local configuration and workspace folders'
"${PNPM[@]}" producer init

step 4 'Building Producer Studio with Webpack'
"${PNPM[@]}" studio:build

STUDIO_PORT="$(node -e 'const fs=require("node:fs"); const config=JSON.parse(fs.readFileSync("producer.config.json", "utf8")); process.stdout.write(String(config.studio?.port ?? 3000));')"

step 5 "Starting Producer Studio at http://127.0.0.1:${STUDIO_PORT}"
export PORT="$STUDIO_PORT"
exec "${PNPM[@]}" studio:start
