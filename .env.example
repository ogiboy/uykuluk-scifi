# UykulukSciFi Producer keeps mock mode by default.
# Copy this file to .env.local only for local provider overrides.
PRODUCER_CONFIG=producer.config.json
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Server-only hosted TTS credential. Never expose this as NEXT_PUBLIC_* or commit a real value.
# ElevenLabs stays disabled until producer.config.json explicitly enables the provider.
ELEVENLABS_API_KEY=
