{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "CHUNK_NO_TELEMETRY=1 chunk validate quick",
            "timeout": 180
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CHUNK_NO_TELEMETRY=1 chunk validate quick",
            "timeout": 180
          }
        ]
      }
    ]
  }
}
